# Database — Local: postgresql://user:pass@localhost:5432/orbita
# Neon:  postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/orbita?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/orbita"

# Auth — Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="generate-a-random-string-with-at-least-32-characters"
JWT_EXPIRES_IN="7d"

# Frontend URL — comma-separated for multiple origins
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
WEB_URL="http://localhost:5173"

PORT=3333
NODE_ENV="development"

# Required for seed script
ADMIN_PASSWORD="your-admin-password"
